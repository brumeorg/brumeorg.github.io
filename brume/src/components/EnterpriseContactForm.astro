---
const t = Astro.locals.t;
const recipient = 'brume.org@gmail.com';
---

<form
	class="brume-form"
	id="brume-enterprise-form"
	data-recipient={recipient}
	data-subject-prefix={t('enterprise.form.subjectPrefix')}
	data-subject-fallback={t('enterprise.form.subjectFallback')}
	data-label-name={t('enterprise.form.labelName')}
	data-label-email={t('enterprise.form.labelEmail')}
	data-label-company={t('enterprise.form.labelCompany')}
	data-label-team={t('enterprise.form.labelTeam')}
	data-sent-via={t('enterprise.form.sentVia')}
>
	<div class="brume-form-grid">
		<label class="brume-form-field">
			<span>{t('enterprise.form.name')}</span>
			<input name="name" type="text" required autocomplete="name" placeholder={t('enterprise.form.namePlaceholder')} />
		</label>
		<label class="brume-form-field">
			<span>{t('enterprise.form.email')}</span>
			<input name="email" type="email" required autocomplete="email" placeholder="jane@acme.com" />
		</label>
		<label class="brume-form-field">
			<span>{t('enterprise.form.company')}</span>
			<input name="company" type="text" required autocomplete="organization" placeholder={t('enterprise.form.companyPlaceholder')} />
		</label>
		<label class="brume-form-field">
			<span>{t('enterprise.form.teamSize')}</span>
			<select name="team_size">
				<option value="">{t('enterprise.form.teamSizeSelect')}</option>
				<option value="1–10">1–10</option>
				<option value="11–50">11–50</option>
				<option value="51–200">51–200</option>
				<option value="200+">200+</option>
			</select>
		</label>
	</div>
	<label class="brume-form-field brume-form-field-wide">
		<span>{t('enterprise.form.message')}</span>
		<textarea
			name="message"
			rows="4"
			required
			placeholder={t('enterprise.form.messagePlaceholder')}
		></textarea>
	</label>
	<div class="brume-form-actions">
		<button type="submit" class="brume-btn brume-btn-primary">
			{t('enterprise.form.submit')}
			<svg class="brume-btn-arrow" viewBox="0 0 16 16" width="16" height="16" aria-hidden="true">
				<path
					fill="none"
					stroke="currentColor"
					stroke-width="1.8"
					stroke-linecap="round"
					stroke-linejoin="round"
					d="M3 8h10M9 4l4 4-4 4"
				></path>
			</svg>
		</button>
		<p class="brume-form-note">
			{t('enterprise.form.note')}
			<a href={`mailto:${recipient}`}>{recipient}</a>{t('enterprise.form.noteOr')}
		</p>
	</div>
</form>

<script is:inline>
	(function () {
		var form = document.getElementById('brume-enterprise-form');
		if (!form) return;
		form.addEventListener('submit', function (e) {
			e.preventDefault();
			var data = new FormData(form);
			var to = form.getAttribute('data-recipient');
			var subjectPrefix = form.getAttribute('data-subject-prefix') || 'Brume Enterprise — ';
			var subjectFallback = form.getAttribute('data-subject-fallback') || 'inquiry';
			var labelName = form.getAttribute('data-label-name') || 'Name:';
			var labelEmail = form.getAttribute('data-label-email') || 'Email:';
			var labelCompany = form.getAttribute('data-label-company') || 'Company:';
			var labelTeam = form.getAttribute('data-label-team') || 'Team:';
			var sentVia = form.getAttribute('data-sent-via') || '';
			var company = (data.get('company') || '').toString().trim();
			var name = (data.get('name') || '').toString().trim();
			var subject = subjectPrefix + (company || subjectFallback);
			var pad = function (s) {
				while (s.length < 10) s += ' ';
				return s;
			};
			var lines = [
				pad(labelName) + name,
				pad(labelEmail) + (data.get('email') || ''),
				pad(labelCompany) + company,
				pad(labelTeam) + (data.get('team_size') || ''),
				'',
				(data.get('message') || '').toString(),
				'',
				'—',
				sentVia,
			];
			var url =
				'mailto:' +
				to +
				'?subject=' +
				encodeURIComponent(subject) +
				'&body=' +
				encodeURIComponent(lines.join('\n'));
			window.location.href = url;
		});
	})();
</script>
