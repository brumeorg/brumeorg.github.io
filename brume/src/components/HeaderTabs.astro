---
const t = Astro.locals.t;
const { pathname } = Astro.url;
const isFrench = pathname.startsWith('/fr/') || pathname === '/fr';
const p = isFrench ? '/fr' : '';

const tabs = [
	{ label: t('header.docs'), href: `${p}/docs/` },
	{ label: t('header.roadmap'), href: `${p}/roadmap/` },
	{ label: t('header.support'), href: `${p}/support/` },
	{ label: t('header.enterprise'), href: `${p}/enterprise/`, cta: true },
];

// Build the URL for the same page in the other locale.
const otherLocaleUrl = isFrench
	? pathname.replace(/^\/fr(\/|$)/, '/')
	: '/fr' + (pathname === '/' ? '/' : pathname);
const otherLocaleLabel = isFrench ? 'EN' : 'FR';
const otherLocaleAria = isFrench ? 'Switch to English' : 'Passer en français';
---

<nav class="header-tabs">
	{
		tabs.map(({ label, href, cta }) => (
			<a
				href={href}
				class:list={[
					{
						active: pathname === href || (pathname.startsWith(href) && href !== '/'),
						cta: cta === true,
					},
				]}
			>
				{label}
			</a>
		))
	}
	<a
		class="lang-switch"
		href={otherLocaleUrl}
		aria-label={otherLocaleAria}
		hreflang={isFrench ? 'en' : 'fr'}
		data-lang-pick={isFrench ? 'en' : 'fr'}
	>
		{otherLocaleLabel}
	</a>
	<a
		href="https://github.com/brumeorg/Brume"
		class="github-link"
		aria-label="GitHub"
		target="_blank"
		rel="noopener noreferrer"
	>
		<svg viewBox="0 0 16 16" width="20" height="20" aria-hidden="true">
			<path
				fill="currentColor"
				d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"
			></path>
		</svg>
	</a>
</nav>

<script is:inline>
	(function () {
		var link = document.querySelector('a.lang-switch[data-lang-pick]');
		if (!link) return;
		link.addEventListener('click', function () {
			try {
				localStorage.setItem('brume_lang', link.getAttribute('data-lang-pick'));
			} catch (e) {}
		});
	})();
</script>

<style>
	.header-tabs {
		display: flex;
		gap: 0.25rem;
		align-items: center;
	}
	.header-tabs a {
		position: relative;
		color: var(--sl-color-gray-2);
		text-decoration: none;
		font-size: var(--sl-text-sm);
		font-weight: 500;
		padding: 0.4rem 0.8rem;
		border-radius: 999px;
		transition: color 0.15s, background-color 0.15s;
	}
	.header-tabs a:hover {
		color: var(--sl-color-white);
		background-color: var(--brume-sage-tint-soft);
	}
	.header-tabs a:focus-visible {
		outline: none;
		box-shadow: 0 0 0 2px var(--brume-sage-glow);
	}
	.header-tabs a.active {
		color: var(--sl-color-white);
	}
	.header-tabs a.active::after {
		content: '';
		position: absolute;
		left: 50%;
		bottom: 0.1rem;
		transform: translateX(-50%);
		width: 18px;
		height: 2px;
		border-radius: 2px;
		background: var(--brume-sage);
	}
	/* Enterprise Edition — tab discrètement contourée */
	.header-tabs a.cta {
		border: 1px solid var(--brume-hairline);
		margin-left: 0.35rem;
	}
	.header-tabs a.cta:hover {
		border-color: var(--brume-sage);
		color: var(--brume-sage);
		background-color: transparent;
	}
	.header-tabs a.cta.active {
		border-color: var(--brume-sage);
		color: var(--brume-sage);
	}
	.header-tabs a.cta.active::after {
		display: none;
	}
	.header-tabs .lang-switch {
		font-size: 0.72rem;
		letter-spacing: 0.06em;
		font-weight: 600;
		padding: 0.35rem 0.55rem;
		margin-left: 0.35rem;
		color: var(--sl-color-gray-3);
	}
	.header-tabs .lang-switch:hover {
		color: var(--brume-sage);
		background-color: transparent;
	}
	.header-tabs .lang-switch.active::after {
		display: none;
	}
	.header-tabs .github-link {
		display: flex;
		align-items: center;
		padding: 0.4rem;
		margin-left: 0.25rem;
		color: var(--sl-color-gray-2);
	}
	.header-tabs .github-link:hover {
		color: var(--sl-color-white);
	}
	.header-tabs .github-link.active::after {
		display: none;
	}
</style>
